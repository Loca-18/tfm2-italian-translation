                             "game_rule_reason":  {
                                                      "game_too_long_1":  "La durata media delle partite è stata troppo lunga questa stagione, quindi acceleriamo il ritmo.",
                                                      "game_too_long_2":  "Le partite prolungate sono state troppo frequenti, alzando il ritmo.",
                                                      "game_too_long_3":  "Le partite stavano finendo troppo tardi, incoraggiando un gioco più dinamico.",
                                                      "game_too_short_1":  "Le partite finivano troppo velocemente, quindi aggiungiamo più profondità strategica.",
                                                      "game_too_short_2":  "Lo snowball precoce era troppo forte, limitando le strategie diverse.",
                                                      "game_too_short_3":  "I tempi di partita brevi lasciavano poco spazio per le rimonte.",
                                                      "morgard_too_strong_1":  "Il tasso di vittoria al primo kill di Morgard è troppo alto, regoliamo il buff.",
                                                      "morgard_too_strong_2":  "Assicurarsi Morgard garantiva quasi la vittoria, ribilanciamo.",
                                                      "morgard_too_strong_3":  "Il buff di Morgard rendeva le partite a senso unico, riduciamo la sua potenza.",
                                                      "morgard_too_weak_1":  "Il valore strategico di Morgard è troppo basso, potenziamo il buff.",
                                                      "morgard_too_weak_2":  "Assicurarsi Morgard non era abbastanza redditizio, lo potenziamo.",
                                                      "morgard_too_weak_3":  "Aumentiamo l'importanza strategica di Morgard potenziando le ricompense.",
                                                      "serpen_too_strong_1":  "Il tasso di vittoria al primo kill di Serpen è troppo alto, regoliamo il buff.",
                                                      "serpen_too_strong_2":  "Assicurarsi Serpen garantiva quasi la vittoria, riduciamo le ricompense statistiche.",
                                                      "serpen_too_strong_3":  "Il buff di Serpen era troppo forte, rendendo il gioco sugli obiettivi a senso unico.",
                                                      "serpen_too_weak_1":  "Il valore strategico di Serpen è troppo basso, aumentiamo le ricompense.",
                                                      "serpen_too_weak_2":  "Assicurarsi Serpen non aveva abbastanza impatto sul gioco, potenziamo il buff.",
                                                      "serpen_too_weak_3":  "Aumentiamo l'importanza di Serpen potenziando le ricompense.",
                                                      "snowball_too_strong_1":  "I vantaggi iniziali si convertivano in vittorie troppo facilmente, aggiungendo potenziale di rimonta.",
                                                      "snowball_too_strong_2":  "Vincere in corsia equivaleva a vincere la partita, rafforzando le opzioni nel late game.",
                                                      "snowball_too_strong_3":  "I divari iniziali si ampliavano troppo velocemente, limitando la diversità strategica.",
                                                      "snowball_too_weak_1":  "Lo snowball era troppo debole nonostante i vantaggi in corsia, potenziamo i vantaggi iniziali.",
                                                      "snowball_too_weak_2":  "I vantaggi iniziali non si trasferivano nel late game, aumentiamone l'impatto.",
                                                      "snowball_too_weak_3":  "I vantaggi nella fase di corsia erano sottovalutati, potenziamo le ricompense iniziali."
                                                  },
