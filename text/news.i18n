                                                   "years":  "FA years",
                                                   "growth":  "Growth",
                                                   "value":  "Value",
                                                   "money":  "Amount",
                                                   "fee":  "Est. cost",
                                                   "ratio":  "Ratio",
                                                   "salary_usage_ratio":  "Salary budget usage",
                                                   "recent_income":  "Recent income",
                                                   "recent_expense":  "Recent expenses",
                                                   "broadcast_income":  "Broadcast revenue",
                                                   "merchandise_income":  "Merchandise revenue",
                                                   "athlete":  "Player",
                                                   "sales":  "Sales",
                                                   "stock":  "Stock",
                                                   "rank":  "Rank",
                                                   "remaining":  "Remaining",
                                                   "rating":  "Rating",
                                                   "region":  "Region",
                                                   "delta":  "Delta",
                                                   "recommend_score":  "Scout score",
                                                   "transfer_budget":  "Transfer budget",
                                                   "salary_budget":  "Salary budget",
                                                   "salary_usage":  "Salary spending",
                                                   "balance":  "Total balance",
                                                   "hours":  "Monthly broadcast time"
                                               },
                                    "team_panel":  "Team operations snapshot",
                                    "opponent_team_panel":  "Opponent team snapshot"
                                },
               "decision":  {
                                "common":  {
                                               "author":  "Team Operations",
                                               "deadline":  "Response Required",
                                               "resolved":  "Decision completed - {Choice}",
                                               "expired":  "No response recorded, default applied automatically - {Choice}",
                                               "no_choice":  "No choice",
                                               "choice_stable":  "Stable",
                                               "choice_aggressive":  "Aggressive",
                                               "choice_relational":  "Relationship"
                                           },
                                "category":  {
                                                 "athlete_psychology":  "Player Psychology",
                                                 "match_preparation":  "Match Preparation",
                                                 "team_operation":  "Team Operations",
                                                 "fan_media":  "Fans/Media",
                                                 "business":  "Business Operations"
                                             },
                                "p01":  {
                                            "title":  "Managing {Athlete}'s Psychological Pressure",
                                            "body":  "{Athlete}'s stress indicator is noticeably higher than usual. A tight training load, the responsibility carried in recent matches, and rapidly growing fan attention may all overlap and start shaking focus from the next match preparation phase.\nPlease decide how to handle the situation.",
                                            "choice":  {
                                                           "stable":  {
                                                                          "title":  "Lower training intensity and let them breathe",
                                                                          "body":  "This week prioritizes reduced training load, rest, and condition recovery. Immediate growth will be slower, but this is the fastest way to calm unstable pressure.",
                                                                          "dialogue":  "Coach: Let him take it easier this week. If we do not give him time to clear his head, the next match gets dragged down too."
                                                                      },
                                                           "aggressive":  {
                                                                              "title":  "Make the starter competition clear",
                                                                              "body":  "The player faces the pressure directly instead of avoiding it. Responsibility becomes clearer, but stress may increase even further.",
                                                                              "dialogue":  "Coach: If avoiding pressure made it disappear, it would be gone already. The one who endures it keeps the spot."
                                                                          },
                                                           "relational":  {
                                                                              "title":  "Resolve it through a staff one-on-one",
                                                                              "body":  "The coaching staff creates time to identify the root of the burden together. The recovery gain is modest, but trust between player and team stays firm.",
                                                                              "dialogue":  "Coach: Have the staff talk to him separately. If he bottles it up until it bursts, then it is too late."
                                                                          }
                                                       }
                                        },
                                "p04":  {
                                            "title":  "Managing {Athlete}'s Condition Recovery",
                                            "body":  "{Athlete}'s condition has fallen into a danger zone. If the next match and training schedule are pushed through unchanged, delayed recovery may become a bigger problem than short-term performance.\nPlease decide the recovery direction.",
                                            "choice":  {
                                                           "stable":  {
                                                                          "title":  "Guarantee a rest schedule",
                                                                          "body":  "Training volume is reduced and rest plus recovery time is secured first. Stamina will be consumed, but condition recovery is the strongest.",
                                                                          "dialogue":  "Coach: Do not push him this week. We need his body back first if we want to use him through the end of the season."
                                                                      },
                                                           "aggressive":  {
                                                                              "title":  "Lift them through match sharpness",
                                                                              "body":  "Instead of resting, the player tries to change the mood through appearances and match sharpness. Match rhythm can recover, but fatigue and stress remain.",
                                                                              "dialogue":  "Coach: Resting will only dull his feel. He will get back faster by playing matches."
                                                                          },
                                                           "relational":  {
                                                                              "title":  "Discuss and adjust the schedule with the player",
                                                                              "body":  "Training items and timing are refined together with the player. Immediate recovery is small, but long-term trust and stability improve.",
                                                                              "dialogue":  "Coach: He knows his body best. Hear him out directly and build the schedule together."
                                                                          }
                                                       }
                                        },
                                "p08":  {
                                            "title":  "Managing Fan Attention on {Athlete}",
                                            "body":  "Fan attention around {Athlete} is growing quickly. Supportive comments, autograph requests, and personal topics are arriving all at once.\nThe response now affects not only the player's burden, but also the wider fan mood around the team.",
                                            "choice":  {
                                                           "stable":  {
                                                                          "title":  "Limit exposure and focus on matches",
                                                                          "body":  "Official-channel exposure is reduced and match preparation takes priority. Fan growth slows, but the player's burden drops clearly.",
                                                                          "dialogue":  "Coach: Cut out the outside noise for now. He only needs to think about the match."
                                                                      },
                                                           "aggressive":  {
                                                                              "title":  "Promote the rising star openly",
                                                                              "body":  "The player's momentum is used aggressively to increase exposure. Fan growth can be expected, but condition and stress risks come with it.",
                                                                              "dialogue":  "Coach: This kind of momentum does not come often. When he is hot, we should lift him up one more time."
                                                                          },
                                                           "relational":  {
                                                                              "title":  "Share the burden through a team message",
                                                                              "body":  "The message shows team preparation and teammate support instead of centering only on one player. Fan response is preserved while the burden is spread out.",
                                                                              "dialogue":  "Coach: If all eyes fall on one player, he carries the burden alone. Handle it as a team message."
                                                                          }
                                                       }
                                        },
                                "m02":  {
                                            "title":  "Gestione della Resistenza Pre-Partita per {Team}",
                                            "body":  "{Team} sta accumulando fatica rapidamente durante il calendario di {League}. Se quella fatica si porta nella prossima partita, gli errori potrebbero aumentare nei set successivi.\nDecidi se mantenere la preparazione invariata o regolare parte del programma.",
                                            "choice":  {
                                                           "stable":  {
                                                                          "title":  "Sposta la preparazione verso il recupero",
                                                                          "body":  "L'intensità dell'allenamento viene abbassata e viene data priorità al recupero pre-partita. L'esplosività iniziale potrebbe diminuire, ma la stabilità e la concentrazione nei set tardivi migliorano.",
                                                                          "dialogue":  "Allenatore: Se dobbiamo arrivare ai set tardivi, la forma fisica viene prima. Taglia un po' di allenamento e usa quel tempo per recuperare."
                                                                      },
                                                           "aggressive":  {
                                                                              "title":  "Mantieni la preparazione ad alta intensità",
                                                                              "body":  "La squadra punta a un vantaggio iniziale e mantiene il forte ritmo di allenamento. Le prestazioni a breve termine possono aumentare, ma la fatica rimane.",
                                                                              "dialogue":  "Allenatore: Mantieni l'intensità. Dobbiamo smuoverli all'inizio e chiuderla; se si trascina, è male per noi."
                                                                          },
                                                           "relational":  {
                                                                              "title":  "Coordina dopo aver sentito la rosa",
                                                                              "body":  "Le opinioni della rosa vengono ascoltate e l'allenamento dettagliato viene regolato. È un compromesso che bilancia recupero e ritmo di partita.",
                                                                              "dialogue":  "Allenatore: Prima ascolta i giocatori e poi decidi. Possiamo regolare senza rompere il loro ritmo."
                                                                          }
                                                       }
                                        },
                                "m09":  {
                                            "title":  "Richiesta di Intervista Pre-Partita dell'Allenatore per {Team}",
                                            "body":  "Con {Days} giorni rimasti prima della partita contro {EnemyTeam}, un'emittente ha richiesto un'intervista all'allenatore. Il tono della risposta influenzerà la concentrazione della rosa e le aspettative dei fan.\nScegli la direzione della risposta.",
                                            "choice":  {
                                                           "stable":  {
                                                                          "title":  "Rispondi brevemente solo con i principi",
                                                                          "body":  "L'esposizione strategica è minimizzata e vengono comunicati solo i principi di preparazione con calma. Non creerà una grande reazione, ma la rosa rimane stabile.",
                                                                          "dialogue":  "Allenatore: Non è necessario esporre le nostre forze. Sii breve: stiamo preparando secondo i nostri principi.{EnemyTeam}"
                                                                      },
                                                           "aggressive":  {
                                                                              "title":  "Accenna a un piano audace e alza l'umore",
                                                                              "body":  "Si mostra forte fiducia per alzare le aspettative dei fan. Le aspettative dei fan salgono, ma la pressione dopo l'intervista può crescere ulteriormente.",
                                                                              "dialogue":  "Allenatore: Dillo chiaramente: questa volta prendiamo il controllo del flusso. Questo è il momento per quel messaggio."
                                                                          },
                                                           "relational":  {
                                                                              "title":  "Enfatizza la fiducia nella rosa",
                                                                              "body":  "Il messaggio si concentra sulla fiducia nei giocatori piuttosto che su una tattica specifica. La reazione dei fan rimane stabile e l'atmosfera dello spogliatoio rimane solida.",
                                                                              "dialogue":  "Allenatore: Non parlare di tattiche; inizia dicendo che ci fidiamo dei giocatori. Quella riga è sufficiente."
                                                                          }
                                                       }
                                        },
                                "t01":  {
                                            "title":  "Regolazione dell'Umore nella Sala Allenamenti per {Team}",
                                            "body":  "All'interno di{Team}, le opinioni differiscono sull'umore da impostare nella sala allenamenti questa settimana. Non si tratta di riscrivere il piano di allenamento stesso, ma di una decisione di gestione a breve termine su condizione, tensione e concentrazione.",
                                            "choice":  {
                                                           "stable":  {
                                                                          "title":  "Mantieni calma la routine di base",
                                                                          "body":  "I dettagli rimangono gli stessi mentre l'umore della sala allenamenti viene organizzato. Il cambiamento immediato è piccolo, ma condizione e concentrazione si assestano naturalmente.",
                                                                          "dialogue":  "Allenatore: Non scuotere le cose per niente; tienila normale. La quiete aiuta in questo momento."
                                                                      },
                                                           "aggressive":  {
                                                                              "title":  "Alza la tensione per spingere la squadra",
                                                                              "body":  "La pressione e la concentrazione vengono alzate più della routine stessa. La condizione può migliorare, ma lo stress aumenta anche.",
                                                                              "dialogue":  "Allenatore: Lo standard sale a partire da oggi. Devono sapere che non terranno il loro posto facendo solo il minimo."
                                                                          },
                                                           "relational":  {
                                                                              "title":  "Senti prima i giocatori principali",
                                                                              "body":  "Lo staff parla prima con i leader dello spogliatoio e poi imposta l'umore. È più lento, ma lo stress diminuisce mentre la lealtà e la concentrazione sono protette.",
                                                                              "dialogue":  "Allenatore: Senti prima i veterani. Se lo spogliatoio non è convinto, l'allenamento non funzionerà."
                                                                          }
                                                       }
                                        },
                                "f01":  {
                                            "title":  "Risposta all'Insoddisfazione dei Fan Attorno a {Team}",
                                            "body":  "L'insoddisfazione dei fan verso {Team} sta crescendo. L'umore della community si è raffreddato troppo per aspettare semplicemente i risultati, ma fare promesse troppo grandi aggiungerebbe vera pressione prima della prossima partita.\nDecidi la direzione della risposta.",
                                            "choice":  {
                                                           "stable":  {
                                                                          "title":  "Rilascia un messaggio ufficiale calmo",
                                                                          "body":  "La direzione del cambiamento è riassunta brevemente e chiaramente. Le aspettative non vengono alzate troppo, mentre l'insoddisfazione può assestarsi di un passo.",
                                                                          "dialogue":  "Allenatore: Dobbiamo riconoscere la situazione. Nessuna promessa che non possiamo mantenere; indica solo cosa cambia adesso."
                                                                      },
                                                           "aggressive":  {
                                                                              "title":  "Prometti un forte rimbalzo",
                                                                              "body":  "La squadra dichiara apertamente che la prossima partita sembrerà diversa. L'attenzione si raccoglie, ma le aspettative salgono altrettanto bruscamente.",
                                                                              "dialogue":  "Allenatore: Di' direttamente che la prossima partita sarà diversa. Se ci tiriamo indietro qui, l'umore si raffredda ancora di più."
                                                                          },
                                                           "relational":  {
                                                                              "title":  "Crea un'opportunità di comunicazione diretta con i fan",
                                                                              "body":  "Viene preparato un luogo per ascoltare le voci dei fan mentre si gestisce il carico della rosa. L'impatto immediato è piccolo, ma aiuta chiaramente a ricostruire la fiducia.",
                                                                              "dialogue":  "Allenatore: Organizza un'opportunità per ascoltare i fan direttamente. Devono sentirsi ascoltati prima di tornare."
                                                                          }
                                                       }
                                        },
                                "f02":  {
                                            "title":  "Sfruttare lo Slancio dei Fan Attorno a {Team}",
                                            "body":  "L'umore dei fan attorno a {Team} sta migliorando rapidamente. Decidi se convertire attivamente questo slancio in entrate e attenzione, o gestirlo naturalmente senza danneggiare la preparazione alla partita.",
                                            "choice":  {
                                                           "stable":  {
                                                                          "title":  "Lascia che lo slancio continui silenziosamente",
                                                                          "body":  "La crescita dei fan viene lasciata scorrere naturalmente senza forzarla più grande. È stabile, ma la crescita rimane limitata.",
                                                                          "dialogue":  "Allenatore: Lascia che l'umore scorra naturalmente. Non vale la pena fare rumore se disturba la preparazione alla partita."
                                                                      },
                                                           "aggressive":  {
                                                                              "title":  "Espandi la campagna ampiamente",
                                                                              "body":  "L'attenzione dei fan viene usata attivamente per aumentare l'esposizione di un altro passo. La crescita dei fan può essere grande, ma il peso delle aspettative crescenti segue.",
                                                                              "dialogue":  "Allenatore: Quando l'umore si sta scaldando, spingere forte una volta. Timing come questo non arriva spesso."
                                                                          },
                                                           "relational":  {
                                                                              "title":  "Rafforza i ringraziamenti e gli eventi fan",
                                                                              "body":  "Il rapporto tra squadra e fan viene messo in primo piano. Questa scelta favorisce la soddisfazione e la lealtà rispetto alla crescita esplosiva.",
                                                                              "dialogue":  "Allenatore: Questo è il momento in cui dovremmo dire grazie correttamente. Organizza un evento e prenditi cura dei fan."
                                                                          }
                                                       }
                                        },
                                "f08":  {
                                            "title":  "Richiesta di Intervista Post-Partita dell'Allenatore per {Team}",
                                            "body":  "Subito dopo la partita contro {EnemyTeam}, i media chiedono l'interpretazione dell'allenatore. Il tono della risposta influenzerà l'opinione dei fan e l'umore della rosa allo stesso tempo.\nScegli la direzione della risposta.",
                                            "choice":  {
                                                           "stable":  {
                                                                          "title":  "Analizza la partita con calma",
                                                                          "body":  "La partita viene riassunta obiettivamente e viene menzionata la prossima preparazione. L'opinione dei fan si stabilizza senza aumentare molto il carico della rosa.",
                                                                          "dialogue":  "Allenatore: Rispondi con calma analizzando la partita di oggi. La vera risposta dovrebbe venire nella prossima partita."
                                                                      },
                                                           "aggressive":  {
                                                                              "title":  "Imposta la direzione con un messaggio forte",
                                                                              "body":  "Anche se crea dibattito, la direzione della squadra viene dichiarata chiaramente. L'attenzione e le aspettative salgono, ma lo stress della rosa potrebbe salire anche.",
                                                                              "dialogue":  "Allenatore: Chiarisci dove stiamo andando. Se qualcuno viene criticato, me ne faccio carico io."
                                                                          },
                                                           "relational":  {
                                                                              "title":  "Proteggi la rosa mettendo i giocatori al primo posto",
                                                                              "body":  "Il messaggio parla prima dello sforzo e del recupero dei giocatori piuttosto che del risultato. Il buzz è limitato, ma la fiducia interna e la soddisfazione dei fan sono protette.",
                                                                              "dialogue":  "Allenatore: Inizia con come si sono preparati i giocatori, non solo con il risultato. Questo non è un posto per demolirli."
                                                                          }
                                                       }
                                        },
                                "b01":  {
                                            "title":  "Direzione della Campagna Merchandise Fan per {Team}",
                                            "body":  "Data la dimensione della fanbase di{Team}, questo è un momento ragionevole per provare una campagna merchandise a breve termine. Non si tratta di cambiare il volume di produzione o il prezzo, ma di una scelta operativa su se dare priorità alle entrate o alla soddisfazione dei fan.",
                                            "choice":  {
                                                           "stable":  {
                                                                          "title":  "Promuovi con cura su piccola scala",
                                                                          "body":  "Le operazioni esistenti rimangono invariate e viene eseguita solo una campagna di vendita conservativa. Le entrate sono piccole, ma il rischio di una cattiva reazione dei fan è basso.",
                                                                          "dialogue":  "Allenatore: Tienilo piccolo questa volta. Se esageriamo con la spinta alle vendite e i fan si raffreddano, questa è la perdita più grande."
                                                                      },
                                                           "aggressive":  {
                                                                              "title":  "Spingere forte una campagna incentrata sulle entrate",
                                                                              "body":  "Il messaggio di vendita viene reso forte per perseguire entrate a breve termine. Le vendite possono crescere, ma le aspettative dei fan e l'insoddisfazione potrebbero fluttuare anche.",
                                                                              "dialogue":  "Allenatore: Quando l'umore è buono, fai il grande swing. Dovremmo prendere le entrate quando possiamo."
                                                                          },
                                                           "relational":  {
                                                                              "title":  "Guida con benefici a misura di fan",
                                                                              "body":  "La campagna rinuncia a un po' di margine e dà priorità alla risposta dei fan. Costa denaro a breve termine, ma la soddisfazione dei fan e la reazione a lungo termine migliorano.",
                                                                              "dialogue":  "Allenatore: Questa volta, dai qualcosa ai fan. Rinunciare al margine ripaga nel lungo termine."
                                                                          }
                                                       }
                                        }
                            }
           }
}