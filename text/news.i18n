               "patch":  {
                             "title":  "Note della Patch v{Version}",
                             "content":  "La patch di bilanciamento v{Version} è stata applicata.\n\nPer i dettagli completi, consulta le note della patch.",
                             "new_champions":  "Newly Added Champions",
                             "adjusted":  "Champion Stat Adjustments",
                             "stat":  "{Stat}: {Pre} -> {Next}",
                             "buff_header":  "Potenziamenti",
                             "nerf_header":  "Indebolimenti",
                             "action_stat":  "{Action} {Stat}: {Pre} -> {Next}",
                             "reason":  {
                                            "too_much_damage_1":  "Damage output has been way too high in recent matches, so we're pulling back the firepower a bit.",
                                            "too_much_damage_2":  "Hitting much harder than intended, leaving opponents with no real way to answer back.",
                                            "too_much_damage_3":  "Damage contribution in teamfights has been over the top, making games feel one-sided.",
                                            "too_tanky_1":  "Opponents simply can't take them down right now, no matter how hard they try.",
                                            "too_tanky_2":  "Durability is way too high, making them nearly impossible to bring down in teamfights.",
                                            "too_tanky_3":  "Staying alive for far too long, leaving opponents with zero window to fight back.",
                                            "too_much_healing_1":  "Healing is so high that kill pressure is basically nonexistent for opponents.",
                                            "too_much_healing_2":  "Health recovery is too fast, making it really hard to get any meaningful trades in.",
                                            "too_much_healing_3":  "Sustain is so overtuned that they rarely lose any exchange.",
                                            "early_game_dominant_1":  "Way too dominant in the laning phase, so we're adjusting base stats.",
                                            "early_game_dominant_2":  "The early leads they generate are dictating the rest of the game too heavily.",
                                            "early_game_dominant_3":  "Early game control is so strong that opponents can't even catch a breath.",
                                            "late_game_scaling_1":  "Scaling is out of control - once the game goes long, they become unbeatable.",
                                            "late_game_scaling_2":  "Gets way too strong as the game drags on, so we're toning down the late game scaling.",
                                            "late_game_scaling_3":  "Overwhelming late game growth has been making games feel completely one-sided.",
                                            "low_damage_1":  "Not delivering the damage we'd expect, so we're giving them a bit more punch.",
                                            "low_damage_2":  "Damage contribution on the team has been lacking - boosting offensive power.",
                                            "low_damage_3":  "Damage numbers have been falling short, so we're reinforcing the firepower.",
                                            "too_fragile_1":  "Going down way too easily to do their job, so we're shoring up their durability.",
                                            "too_fragile_2":  "Not enough room for positioning in teamfights - giving them a bit more survivability.",
                                            "too_fragile_3":  "Survivability is so low that just joining a fight feels like a risk. Addressing that.",
                                            "low_healing_1":  "Healing isn't pulling its weight, and it shows in how little they contribute in fights.",
                                            "low_healing_2":  "Sustain is too low to hold up in extended fights, so we're patching that up.",
                                            "low_healing_3":  "Health sustain is lacking enough that they can't properly fulfill their role. Improving that.",
                                            "weak_early_game_1":  "Early game is so rough they can barely survive laning phase - giving them a hand.",
                                            "weak_early_game_2":  "Fundamentals are too weak early on to get anything going, so we're bumping up base stats.",
                                            "weak_early_game_3":  "Getting pushed around way too easily in lane, so we're strengthening base stats.",
                                            "weak_late_game_1":  "Fading into irrelevance as the game goes on - addressing that.",
                                            "weak_late_game_2":  "Impact drops off a cliff in longer games, so we're improving late game scaling.",
                                            "weak_late_game_3":  "Late game weakness is really showing - reinforcing growth stats.",
                                            "nerf_meta_1":  "Has been sitting at the top of the meta for several patches now, so we're going in harder this time.",
                                            "nerf_meta_2":  "A ban/pick staple for quite a while - taking this chance to bring them down meaningfully.",
                                            "nerf_meta_3":  "Has been at the center of the meta for too long. Time to take a step back.",
                                            "buff_meta_1":  "Has been underperforming for a while now, so we're giving them a real boost this time.",
                                            "buff_meta_2":  "Struggling across multiple patches - putting some more power into their kit.",
                                            "buff_meta_3":  "Has been unable to find a footing for a while, so we're giving proper support this patch.",
                                            "unpicked_1":  "Barely seeing any play at all, so we're buffing across the board.",
                                            "unpicked_2":  "Pick rate is low in both solo queue and competitive - adding some appeal.",
                                            "unpicked_3":  "Hasn't had a chance to shine in a while, so we're opening up opportunities for them.",
                                            "unpicked_long":  "È rimasto fuori dalla scena per molto tempo. Diamo una spinta significativa per aiutarlo a tornare.",
                                            "dominant":  "Ha dominato il meta per troppo tempo. Abbassiamo leggermente le statistiche per bilanciare.",
                                            "underperforming":  "Le prestazioni sono state costantemente basse. Aumentiamo le statistiche per dargli più spazio."
                                        },
