                                                                      "0":  "Bloodbath! {MyTeam} vs {EnemyTeam} Goes the Distance, {MyScore}-{EnemyScore} Final",
                                                                      "1":  "Nail-Biter Full Set! {MyTeam} Edges {EnemyTeam} in Epic Clash {MyScore}-{EnemyScore}",
                                                                      "2":  "No Quarter Given! {MyTeam} vs {EnemyTeam} Decided After Full Set Thriller {MyScore}-{EnemyScore}"
                                                                  },
                                                  "win_streak":  {
                                                                     "0":  "Unstoppable! {MyTeam} Takes Down {EnemyTeam} to Extend Win Streak to {Count}",
                                                                     "1":  "Can't Be Stopped! {MyTeam} Rolls Past {EnemyTeam} for {Count} Straight Wins",
                                                                     "2":  "{Count}-Game Win Streak! {MyTeam} Adds {EnemyTeam} to Their List, Keeps Soaring"
                                                                 },
                                                  "loss_streak":  {
                                                                      "0":  "{MyTeam} Sinks Deeper... Falls to {EnemyTeam}, Extends Losing Skid to {Count}",
                                                                      "1":  "Nightmare Won't End... {MyTeam} Drops to {EnemyTeam} for {Count}th Straight Loss",
                                                                      "2":  "{MyTeam} Mired in Slump... {Count}-Game Losing Streak After {EnemyTeam} Defeat"
                                                                  },
                                                  "mvp_carry":  {
                                                                    "0":  "\"Where Would They Be Without {MvpName}\" {MyTeam} Rides Ace to {MyScore}-{EnemyScore} Win",
                                                                    "1":  "{MvpName} Saves the Day! Heroic Carry Powers {MyTeam} to {MyScore}-{EnemyScore} Victory",
                                                                    "2":  "One-Man Show! {MvpName} Goes Off, {MyTeam} Beats {EnemyTeam} {MyScore}-{EnemyScore}"
                                                                },
                                                  "long_game":  {
                                                                    "0":  "Endless Battle... {MyTeam} vs {EnemyTeam} Marathon Ends {MyScore}-{EnemyScore}",
                                                                    "1":  "Marathon Match! {MyTeam} vs {EnemyTeam} Settled After Grueling War {MyScore}-{EnemyScore}",
                                                                    "2":  "Iron Will! {MyTeam} Outlasts {EnemyTeam} in Ultra-Long Series {MyScore}-{EnemyScore}"
                                                                }
                                              },
                                    "body":  {
                                                 "default_win":  "{MyTeam} secured victory over {EnemyTeam} with a set score of {MyScore}-{EnemyScore}. The entire roster delivered consistent performances, guiding the match with composure. While {EnemyTeam} put up a fight, they couldn't match {MyTeam}'s focus in the critical moments.",
                                                 "default_lose":  "{MyTeam} lost to {EnemyTeam} by a set score of {EnemyScore}-{MyScore}. They were dragged around all match without taking control, and mistakes in key fights kept piling up. Strategic adjustments look urgent before the next match.",
                                                 "clean_sweep":  "A flawless performance. {MyTeam} shut out {EnemyTeam} {MyScore}-{EnemyScore} without conceding a single set. From the first set to the last, unwavering execution crushed any hope of a comeback. {EnemyTeam} could find no answers and crumbled helplessly.",
                                                 "comeback":  "They never gave up. {MyTeam} dropped the opening sets to {EnemyTeam} and stood on the edge of elimination, but summoned incredible focus to reel off consecutive sets in a dramatic turnaround. Final score: {MyScore}-{EnemyScore}. Unshakeable mental fortitude proved the difference when defeat seemed certain.",
                                                 "reverse_sweep_lose":  "A lead thrown away. {MyTeam} took the early sets against {EnemyTeam} and held the high ground, but momentum shifted violently as they surrendered consecutive sets, suffering a crushing {EnemyScore}-{MyScore} reverse sweep. A fundamental review of their inability to close out matches from winning positions is needed.",
                                                 "dominant_victory":  "{MyTeam} claimed a commanding {MyScore}-{EnemyScore} victory over {EnemyTeam}. They built massive kill leads across every set, turning the series into a one-sided affair. From lane phase to late-game teamfights, {EnemyTeam} was completely outmatched at every stage.",
                                                 "close_match":  "A breathtaking series. {MyTeam} and {EnemyTeam} battled through a full set in a fierce war of attrition, ultimately finishing {MyScore}-{EnemyScore}. Neither side gave an inch, delivering a tense series where every set's teamfights swung back and forth.",
                                                 "win_streak":  "The momentum is frightening. {MyTeam} extended their win streak to {Count} games by toppling {EnemyTeam}. Final score: {MyScore}-{EnemyScore}. With each passing match, the team's synergy looks sharper than ever.",
                                                 "loss_streak":  "No light at the end of the tunnel. {MyTeam} dropped to {EnemyTeam} {EnemyScore}-{MyScore}, sinking deeper into a {Count}-game losing streak. The same mistakes keep repeating, which is the most painful takeaway. With squad morale a growing concern, they desperately need a spark to turn things around.",
                                                 "mvp_carry":  "{MvpName} saved the match. {MyTeam} defeated {EnemyTeam} {MyScore}-{EnemyScore}. Whenever the team wavered, {MvpName} brought the momentum back with decisive plays, and the carry performance in key fights was especially impressive.",
                                                 "long_game":  "A marathon match. {MyTeam} and {EnemyTeam} finally settled things {MyScore}-{EnemyScore} after an endless war of attrition. Both teams played with surgical precision, refusing to allow any decisive engagements, and spectators were on the edge of their seats through the prolonged tug-of-war."
                                             },
                                    "set_summary":  {
                                                        "default":  {
                                                                        "0":  "Both teams started cautiously with no significant gap in the lane phase. The tide began to turn at the first mid-game objective fight, and from that point one side seized control and dictated the pace.",
                                                                        "1":  "Both teams' draft strategies clashed from the opening minutes. Jungle pathing was the key battleground in the early-to-mid game, and the side that leveraged lane priority and vision control to secure objectives took the upper hand.",
                                                                        "2":  "Individual skill was on full display this set. Solo kills broke out across multiple lanes in heated exchanges, and ultimately the team that showed better judgment in full-scale teamfights claimed the advantage."
                                                                    },
                                                        "dominant_win":  {
                                                                             "0":  "It was one-sided from start to finish. After building an overwhelming lead in lane phase, they left no openings in mid-game fights, completely locking down the match. There was not even a thread of hope for a comeback.",
                                                                             "1":  "A complete strategic masterclass. The winning side neutralized the opponent's core strategy from the draft, then dominated both lanes and jungle pathing without contest.",
                                                                             "2":  "The momentum swung entirely to one side from the first skirmish. Kills piled up and the gap snowballed out of control, with the outcome effectively decided well before the game ended."
                                                                         },
                                                        "close_game":  {
                                                                           "0":  "A breathless contest from start to finish. The tug-of-war began in lane phase, with kills traded back and forth in every fight as neither side yielded. It all came down to the final teamfight, where {MvpName} made the razor-thin difference.",
                                                                           "1":  "The slimmest of margins decided this razor-sharp contest. Both teams executed flawless macro play, and fights erupted around every objective. {MvpName} delivered a standout performance, standing at the center of this knife-edge battle.",
                                                                           "2":  "Both teams fought as if their lives depended on it. From early game to late, kill scores stayed nearly even as the arena was gripped by extreme tension. In the end, {MvpName}'s decisive play in the final teamfight tipped the scales."
                                                                       },
                                                        "comeback":  {
                                                                         "0":  "A dramatic comeback for the ages. Trailing heavily in kills with defeat looking certain, they strung together crucial fight wins from mid-game onward to completely reverse the flow. {MvpName}'s one-man show laid the foundation for the turnaround. Never give up.",
                                                                         "1":  "This is what a comeback tastes like. Despite falling behind early, patient preparation for the late game paid off with one explosive objective fight that flipped the script entirely. {MvpName} carried the team on their back, turning the impossible into reality.",
                                                                         "2":  "The game isn't over until it's over. Unfavorable fights continued throughout the early and mid game, but one perfect teamfight turned everything upside down. {MvpName}'s clutch play pulled the team back from the brink."
                                                                     },
                                                        "long_game":  {
                                                                          "0":  "An epic {Minutes}-minute marathon. Both teams played with extreme caution, refusing to commit to decisive engagements. After extended standoffs and small skirmishes, the final teamfight at last brought the long contest to a close.",
                                                                          "1":  "A seemingly endless war of attrition. For {Minutes} minutes, both sides executed meticulous macro without tolerating a single mistake, as mind games around objectives dominated the mid-to-late game.",
                                                                          "2":  "A staggering {Minutes} minutes - a true marathon. Under extreme pressure where one wrong call meant defeat, neither team backed down until the very end."
                                                                      },
                                                        "short_game":  {
                                                                           "0":  "It was over in the blink of an eye. In just {Minutes} minutes, aggressive plays from the opening suffocated the opposition. Kills chained together and the gap spiraled out of control in an instant.",
                                                                           "1":  "{Minutes} minutes - a record-breaking blitz. Momentum swung completely to one side from the first skirmish, with kills pouring in before lanes even had a chance to settle.",
                                                                           "2":  "A storm hit the moment the game began. Fighting broke out from the opening invade, and in a scarcely believable {Minutes} minutes, it was all over."
                                                                       },
                                                        "mvp_performance":  {
                                                                                "0":  "{MvpName} was the undisputed star of this set. With a dominant {Kills}/{Deaths}/{Assists} scoreline, they tore through the enemy ranks in every teamfight, carrying the team on their shoulders. The opposition threw everything they had at {MvpName}, but it wasn't enough.",
                                                                                "1":  "A one-person army. {MvpName} put up a monstrous {Kills}/{Deaths}/{Assists} performance, utterly dominating the game. After overwhelming their lane opponent, they played a pivotal role in every teamfight to lead the team to victory.",
                                                                                "2":  "{MvpName} was on another level today. {Kills}/{Deaths}/{Assists} - the numbers speak for themselves. Seizing control with aggressive plays from the start, they elevated the team's fighting power in every mid-to-late game engagement, showcasing an overwhelming presence."
                                                                            }
                                                    }
