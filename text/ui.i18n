                                                      "fearless":  "Режим Fearless",
                                                      "fearless_desc":  "В рамках одного матча команды не могут выбирать чемпионов, на которых они уже играли в предыдущих сетах.",
                                                      "fearless_hard":  "Режим Hard Fearless",
                                                      "fearless_hard_desc":  "В рамках одного матча запрещено выбирать чемпионов, на которых играла любая из двух команд в предыдущих сетах."
                                                  },
                                "league_rule":  {
                                                    "header":  "Правила лиги",
                                                    "double":  "Двойная сетка",
                                                    "double_desc":  "Плей-офф лиги пройдет по системе с нижней сеткой: команда выбывает только после двух поражений.",
                                                    "tournament":  "Одиночная сетка",
                                                    "tournament_desc":  "Плей-офф лиги пройдет по классической олимпийской системе: команда выбывает из турнира сразу после первого же поражения."
                                                },
                                "cup_rule":  {
                                                 "header":  "Правила международных турниров",
                                                 "double":  "Двойная сетка",
                                                 "double_desc":  "Плей-офф международных турниров пройдёт по системе с нижней сеткой: команды покинут чемпионат только после двух поражений.",
                                                 "tournament":  "Одиночная сетка",
                                                 "tournament_desc":  "Финальная стадия кубка пройдет по классической олимпийской системе: у команд не будет права на ошибку — проигравший сразу выбывает."
                                             },
                                "group_stage_rule":  {
                                                         "header":  "Правила группового этапа",
                                                         "league_group":  "Групповая лига",
                                                         "league_group_desc":  "Групповой этап чемпионата проходит в формате круговой системы (4 группы). Две лучшие команды из каждой группы выходят в стадию плей-офф.",
                                                         "swiss":  "Швейцарская система",
                                                         "swiss_desc":  "Групповой этап международного турнира пройдёт по швейцарской системе для 16 команд. Игра идёт до 3 побед или 3 поражений — всего в плей-офф выйдут 8 лучших команд."
                                                     },
                                "simulation_intensity":  {
                                                             "header":  "Детализация симуляции",
                                                             "weak":  "Простая",
                                                             "weak_desc":  "Точно симулируются только матчи вашей лиги и соло-рейтинг вашей команды. Все остальные матчи рассчитываются в упрощенном виде без возможности просмотра повторов. Этот режим дает минимальную нагрузку на систему и рекомендуется для слабых ПК. На вашем устройстве симуляция одного игрового дня займет от {min_time} до {max_time} сек.",
                                                             "normal":  "Средняя",
                                                             "normal_desc":  "Точно симулируются матчи вашей лиги, соло-рейтинг вашей команды и регулярные сезоны других лиг. Остальные матчи рассчитываются в упрощенном виде без возможности просмотра повторов. Режим дает умеренную нагрузку на систему и рекомендуется для ПК средней мощности. На вашем устройстве симуляция одного игрового дня займет от {min_time} до {max_time} сек.",
                                                             "strong":  "Подробная",
                                                             "strong_desc":  "Абсолютно все типы матчей симулируются с полной точностью. Этот режим дает максимальную нагрузку на систему и рекомендуется только для мощных ПК. Время загрузки может заметно увеличиться. На вашем устройстве симуляция одного игрового дня займет от {min_time} до {max_time} сек."
                                                         },
                                "view_stat":  {
                                                  "header":  "Видимость характеристик игрока",
                                                  "hide":  "Скрыть",
                                                  "hide_desc":  "Характеристики игроков будут скрыты и зависят от уровня осведомленности вашей команды. Отправляйте скаутов на задания или проводите матчи, чтобы постепенно открывать более точные данные о параметрах игроков.",
                                                  "view":  "Показать",
                                                  "view_desc":  "Характеристики всех игроков будут полностью открыты с самого начала игры, независимо от уровня скаутинга вашей команды."
                                              },
