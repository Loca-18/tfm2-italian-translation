                               "coach_dialogue_prediction_correction_basic_v2":  "La lecture sur {Champion} a changé. Le poids bascule vers {Position}. Probabilité actuelle : {Chance}%.",
                               "coach_dialogue_prediction_correction_detail":  "La forme du draft a changé, donc j'ajuste la lecture. {Champion} penche maintenant vers {Position}. Selon {Evidence}, probabilité {Chance}%, taux de victoire {WinRate}%, or moyen en lane {EnemyGold}.",
                               "coach_dialogue_recommendation_basic":  "{Position} peut se répondre avec {OurChampion}. Il vaut mieux le garder comme {CandidateType}.",
                               "coach_dialogue_recommendation_basic_v2":  "Pour répondre à {Position}, je recommande {OurChampion}. Il vaut mieux le retenir comme {CandidateType}.",
                               "coach_dialogue_recommendation_basic_v3":  "{OurChampion} est bon pour {Position}. Vous pouvez le garder comme {CandidateType}.",
                               "coach_dialogue_recommendation_detail":  "Vu le déroulé du draft, il vaut mieux préparer d'abord la réponse à {Position}. Gardez {OurChampion} comme {CandidateType} et confirmez au prochain tour.",
                               "coach_dialogue_recommendation_detail_v2":  "Il vaut mieux régler {Position} d'abord. Garder {OurChampion} comme {CandidateType} devrait faciliter le prochain pick.",
                               "coach_dialogue_general_recommendation_basic":  "Pour {Position}, mieux vaut sécuriser {OurChampion} tôt. Cela vaut la peine de le garder comme {CandidateType}.",
                               "coach_dialogue_general_recommendation_detail":  "Comme {Position} reste ouvert, mieux vaut sécuriser {OurChampion} tôt. Le faire monter comme {CandidateType} semble être une bonne option.",
                               "coach_dialogue_recommendation_support_basic":  "Pour {Player}, {OurChampion} contre {EnemyChampion} montre {SoloKillRate}% de pression de solo kill et {GoldDiff} d'écart d'or en lane.",
                               "coach_dialogue_recommendation_support_basic_v2":  "D'après les données, {OurChampion} contre {EnemyChampion} montre {SoloKillRate}% de pression de solo kill et {GoldDiff} d'écart d'or en lane.",
                               "coach_dialogue_recommendation_support_detail":  "Pour {Player}, {OurChampion} contre {EnemyChampion} montre {SoloKillRate}% de pression de solo kill, {GoldDiff} d'écart d'or en lane et {WinRate}% d'avantage attendu. {Sample}.",
                               "coach_dialogue_ban_recommendation_basic":  "Pour l’instant, {OurChampion} mérite de remonter comme candidat au ban.",
                               "coach_dialogue_ban_recommendation_detail":  "À ce stade, {OurChampion} doit être traité comme candidat au ban de plus haute priorité.",
                               "coach_dialogue_ban_warning":  "{Player} maîtrise très bien {Champion}. Je le recommande comme priorité de ban numéro un.",
                               "coach_dialogue_ban_warning_v2":  "{Champion} avec {Player} est dangereux. Je recommande de le retirer avec un ban.",
                               "coach_dialogue_enemy_tendency":  "L'adversaire a récemment souvent utilisé des picks comme {OurChampion}. Mieux vaut s'y préparer.",
                               "coach_dialogue_enemy_tendency_v2":  "{OurChampion} est une carte que l'adversaire sort souvent. Comme elle a de bonnes chances d'apparaître, il vaut mieux s'y préparer.",
                               "coach_dialogue_weak_lane":  "Dans la composition adverse, {Position} est la position la plus faible. Ce point mérite d'être attaqué.",
                               "coach_dialogue_weak_lane_v2":  "Le point d'attaque est {Position}. C'est là que l'adversaire est le plus léger.",
                               "coach_dialogue_history_tooltip":  "Staff dialogue history",
                               "coach_dialogue_toast_show_tooltip":  "Show staff dialogue",
                               "coach_dialogue_toast_hide_tooltip":  "Hide staff dialogue",
                               "coach_dialogue_stats_source_team":  "opponent recent record",
                               "coach_dialogue_stats_source_patch":  "patch statistics",
                               "coach_dialogue_stats_source_position_model":  "picks publics et statistiques de position",
                               "coach_dialogue_stats_sample_none":  "Faute de données directes suffisantes sur ce duel, la valeur est ajustée avec les statistiques du patch et les données du joueur",
                               "coach_dialogue_evidence_games":  "{Source}, {Sample} games",
                               "coach_dialogue_sample_games":  "Cette valeur utilise {Sample} parties de comparaison directe",
                               "coach_dialogue_unknown_player":  "Opponent player",
                               "coach_dialogue_unknown_position":  "key lane",
                               "coach_dialogue_swap_enemy_prediction":  "À l'étape de swap, la répartition de lanes adverse la plus probable est {EnemyLayout}.",
                               "coach_dialogue_swap_allocation":  "Pour notre répartition de lanes, {OurLayout} semble être le meilleur choix. La recommandation tient compte de la maîtrise des joueurs et des positions principales des champions.",
