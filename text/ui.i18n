                                  "coach_dialogue_title":  "Staff Dialogue",
                                  "coach_dialogue_role_head":  "Head Coach",
                                  "coach_dialogue_role_analyst":  "Analyst",
                                  "coach_dialogue_role_staff":  "Coach",
                                  "coach_dialogue_candidate_type_ban":  "ban candidates",
                                  "coach_dialogue_candidate_type_pick":  "pick candidates",
                                  "coach_dialogue_opening_analyst":  "O adversário ainda não revelou nenhum pick. Quando o primeiro pick aparecer, vou apontar primeiro a posição provável.",
                                  "coach_dialogue_opening_analyst_v2":  "O adversário ainda não escolheu. Assim que for revelado, vou resumir a leitura de posição e as tendências recentes de picks.",
                                  "coach_dialogue_opening_head":  "Não precisa ter pressa. Confira o primeiro pick deles e depois comece por uma das nossas posições fortes.",
                                  "coach_dialogue_opening_head_v2":  "Não é preciso acelerar. Depois de ver a resposta deles, um pick que use nossas forças deve ser bom.",
                                  "coach_dialogue_prediction_basic":  "Estimo {Champion} em {Position} com {Chance}% de chance.",
                                  "coach_dialogue_prediction_basic_v2":  "A posição prevista para {Champion} é {Position}. A chance é {Chance}%.",
                                  "coach_dialogue_prediction_basic_v3":  "{Champion} tende a ir para {Position}, com {Chance}% de chance.",
                                  "coach_dialogue_prediction_detail":  "Espero {Champion} em {Position}. Com base em {Evidence}, a chance é {Chance}%, a taxa de vitória na posição é {WinRate}%, o ouro médio de rota é {EnemyGold} e a média de abates é {EnemyKills}.",
                                  "coach_dialogue_prediction_detail_v2":  "A posição prevista para {Champion} é {Position}. Com base em {Evidence}, chance de {Chance}%, taxa de vitória {WinRate}% e ouro médio de rota em torno de {EnemyGold}.",
                                  "coach_dialogue_prediction_correction_basic":  "Estou ajustando a leitura. {Champion} agora tem mais chance de ir para {Position} do que para {PreviousPosition}. Chance atual: {Chance}%.",
                                  "coach_dialogue_prediction_correction_basic_v2":  "A leitura sobre {Champion} mudou. O peso agora está em {Position}. Chance atual: {Chance}%.",
                                  "coach_dialogue_prediction_correction_detail":  "A forma do draft mudou, então estou ajustando a leitura. {Champion} agora pende para {Position}. Com base em {Evidence}, chance {Chance}%, taxa de vitória {WinRate}% e ouro médio de rota {EnemyGold}.",
                                  "coach_dialogue_recommendation_basic":  "{Position} pode ser respondida com {OurChampion}. É bom manter como {CandidateType}.",
                                  "coach_dialogue_recommendation_basic_v2":  "Para responder {Position}, recomendo {OurChampion}. É bom filtrar como {CandidateType}.",
                                  "coach_dialogue_recommendation_basic_v3":  "{OurChampion} é bom para {Position}. Pode manter como {CandidateType}.",
                                  "coach_dialogue_recommendation_detail":  "Pelo fluxo, é melhor preparar primeiro a resposta para {Position}. Mantenha {OurChampion} como {CandidateType} e confirme no próximo turno.",
                                  "coach_dialogue_recommendation_detail_v2":  "É melhor resolver {Position} primeiro. Manter {OurChampion} como {CandidateType} deve facilitar o próximo pick.",
                                  "coach_dialogue_general_recommendation_basic":  "Para {Position}, é melhor garantir {OurChampion} cedo. Vale tratar como {CandidateType}.",
                                  "coach_dialogue_general_recommendation_detail":  "Como {Position} ainda está aberto, é melhor garantir {OurChampion} cedo. Aumentar a prioridade como {CandidateType} parece bom.",
                                  "coach_dialogue_recommendation_support_basic":  "Para {Player}, {OurChampion} contra {EnemyChampion} mostra {SoloKillRate}% de pressão de solo kill e {GoldDiff} de diferença de ouro na rota.",
                                  "coach_dialogue_recommendation_support_basic_v2":  "Pelos dados, {OurChampion} contra {EnemyChampion} mostra {SoloKillRate}% de pressão de solo kill e {GoldDiff} de diferença de ouro na rota.",
                                  "coach_dialogue_recommendation_support_detail":  "Para {Player}, {OurChampion} contra {EnemyChampion} mostra {SoloKillRate}% de pressão de solo kill, {GoldDiff} de diferença de ouro na rota e {WinRate}% de vantagem esperada. {Sample}.",
                                  "coach_dialogue_ban_recommendation_basic":  "Agora vale subir {OurChampion} como candidato a ban.",
                                  "coach_dialogue_ban_recommendation_detail":  "Nesta etapa, {OurChampion} deve ser tratado como candidato a ban de prioridade mais alta.",
                                  "coach_dialogue_ban_warning":  "{Player} tem proficiência muito alta com {Champion}. Recomendo como prioridade máxima de ban.",
                                  "coach_dialogue_ban_warning_v2":  "{Champion} nas mãos de {Player} é perigoso. Recomendo remover com ban.",
                                  "coach_dialogue_enemy_tendency":  "O adversário tem usado picks como {OurChampion} com frequência recentemente. Vale preparar uma resposta antes.",
                                  "coach_dialogue_enemy_tendency_v2":  "{OurChampion} é uma carta que o adversário costuma usar. Como a chance de aparecer é alta, é melhor se preparar.",
                                  "coach_dialogue_weak_lane":  "Na escalação adversária, {Position} é a posição mais fraca. Vale atacar esse ponto.",
                                  "coach_dialogue_weak_lane_v2":  "O ponto de ataque é {Position}. O adversário está mais frágil nessa posição.",
