                                          "position_header":  "位置",
                                          "add_position":  "添加位置",
                                          "communication_header":  "沟通水平",
                                          "add_language":  "添加赛区",
                                          "growth_header":  "成长",
                                          "potential":  "潜力",
                                          "stamina_recovery_min":  "体力恢复最小值",
                                          "stamina_recovery_max":  "体力恢复最大值",
                                          "stamina_cost_per_set_min":  "体力消耗最小值",
                                          "stamina_cost_per_set_max":  "体力消耗最大值",
                                          "stress_sensitivity":  "压力敏感度",
                                          "condition_baseline":  "状态基准值",
                                          "condition_amplitude":  "状态起伏程度",
                                          "condition_period":  "状态起伏周期",
                                          "condition_phase":  "状态起伏相位",
                                          "match_impact_sensitivity":  "比赛结果重视度",
                                          "fan_count":  "粉丝数",
                                          "description":  {
                                                              "potential":  "该能力值越高，就越容易通过训练获得成长，同时成长潜力等级也会更高。",
                                                              "stamina_recovery_min":  "每日恢复体力随机幅度的最小值。",
                                                              "stamina_recovery_max":  "每日恢复体力随机幅度的最大值。",
                                                              "stamina_cost_per_set_min":  "参加一局比赛时所消耗体力随机幅度的最小值。实际消耗量将根据比赛时间进行校正。",
                                                              "stamina_cost_per_set_max":  "参加一局比赛时所消耗体力随机幅度的最大值。实际消耗量将根据比赛时间进行校正。",
                                                              "stress_sensitivity":  "该能力值越高，在休息不足时压力就越容易累积，并且通过休息所减少的压力幅度也越小。",
                                                              "condition_baseline":  "状态围绕基准值进行波动，基准值越高，总体状态越好。",
                                                              "condition_amplitude":  "该能力值越高，选手状态围绕基准值的变化幅度就越大，即状态波动上下限范围越大。",
                                                              "condition_period":  "完成一个状态变化周期所需的天数。该数值越低，状态波动的情况就越频繁，越容易在状态最佳与状态最差间不断转换。",
                                                              "condition_phase":  "该值用于前后推移状态变化的具体日期。当相位不同时，即使两名选手状态周期相同，他们各自状态好与状态差的日子到来的时间点也不同。",
                                                              "match_impact_sensitivity":  "比赛后胜负及是否获得mvp对状态造成影响的强弱程度。50为标准值，0表示完全没有影响，100表示影响加倍。",
                                                              "fan_count":  "选手的粉丝数量。用于计算直播观众数、商品销量以及比赛后选手粉丝数量的变化。"
                                                          },
