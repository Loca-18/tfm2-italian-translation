                                                         "league_group":  "Thể thức Bảng",
                                                         "league_group_desc":  "Vòng Bảng Giải đấu sẽ được chia thành 4 bảng, thi đấu theo thể thức vòng tròn. 2 đội đứng đầu mỗi bảng sẽ tiến vào vòng loại trực tiếp.",
                                                         "swiss":  "Thể thức Thuỵ Sĩ",
                                                         "swiss_desc":  "Vòng Bảng sẽ diễn ra theo Thể thức Thụy Sĩ với 5 vòng và 16 đội chung một bảng. Đội thắng 3 trận sẽ lọt vào vòng loại trực tiếp, thua 3 trận sẽ bị loại. Tổng cộng sẽ có 8 đội tiến vào vòng trong."
                                                     },
                                "simulation_intensity":  {
                                                             "header":  "Cường độ Mô phỏng",
                                                             "weak":  "Yếu",
                                                             "weak_desc":  "Hệ thống chỉ mô phỏng chi tiết các Trận đấu và Xếp hạng đơn thuộc Giải đấu mà Đội bạn đang tham gia. Các Giải đấu và Xếp hạng của khu vực khác sẽ được mô phỏng giản lược. Bạn không thể xem Replay đối với các trận đấu mô phỏng giản lược. Khuyên dùng cho các thiết bị cấu hình thấp. Dựa trên thiết bị hiện tại, một ngày mô phỏng sẽ cần khoảng {min_time} đến {max_time} giây.",
                                                             "normal":  "Trung Bình",
                                                             "normal_desc":  "Hệ thống sẽ mô phỏng chi tiết các Trận đấu và Xếp hạng đơn thuộc Giải đấu Đội bạn tham gia, cùng với các Trận đấu chính thức của những Giải đấu khác. Phần còn lại sẽ được mô phỏng giản lược. Bạn không thể xem Replay của các Trận đấu mô phỏng giản lược. Khuyên dùng cho thiết bị cấu hình tầm trung. Thời gian tải có thể kéo dài hơn. Dựa trên thiết bị hiện tại, một ngày mô phỏng sẽ cần khoảng {min_time} đến {max_time} giây.",
                                                             "strong":  "Mạnh",
                                                             "strong_desc":  "Hệ thống sẽ mô phỏng chi tiết tất cả các loại Trận đấu. Khuyên dùng cho các thiết bị cấu hình Mạnh. Thời gian tải có thể kéo dài đáng kể. Dựa trên thiết bị hiện tại, một ngày mô phỏng sẽ cần khoảng {min_time} đến {max_time} giây."
                                                         },
                                "view_stat":  {
