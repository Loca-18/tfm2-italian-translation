                               "coach_dialogue_stats_source_patch":  "patch statistics",
                               "coach_dialogue_stats_source_position_model":  "öffentliche Picks und Positionsstatistiken",
                               "coach_dialogue_stats_sample_none":  "Mangels direkter Matchup-Daten ist dieser Wert aus Patch-Statistiken und Spielerwerten angepasst",
                               "coach_dialogue_evidence_games":  "{Source}, {Sample} games",
                               "coach_dialogue_sample_games":  "Dieser Wert berücksichtigt {Sample} direkte Vergleichsspiele",
                               "coach_dialogue_unknown_player":  "Opponent player",
                               "coach_dialogue_unknown_position":  "key lane",
                               "coach_dialogue_swap_enemy_prediction":  "In der Swap-Phase wirkt die gegnerische Lane-Aufteilung {EnemyLayout} am wahrscheinlichsten.",
                               "coach_dialogue_swap_allocation":  "Für unsere Lane-Aufteilung sieht {OurLayout} am besten aus. Die Empfehlung gewichtet Spielerstärke und Hauptpositionen der Champions.",
