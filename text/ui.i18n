                               "coach_dialogue_opening_analyst_v2":  "The opponent has not picked yet. As soon as it is revealed, I will summarize the position read and recent pick tendencies for you.",
                               "coach_dialogue_opening_head":  "Non c'è fretta. Controlla prima il loro primo pick, poi inizia da una delle nostre posizioni di forza.",
                               "coach_dialogue_opening_head_v2":  "You do not need to hurry. After seeing their response, going with a pick that uses our strengths should be good.",
                               "coach_dialogue_prediction_basic":  "Stimo {Champion} in {Position} con una probabilità del {Chance}%.",
                               "coach_dialogue_prediction_basic_v2":  "La posizione attesa per {Champion} è {Position}. La probabilità è del {Chance}%.",
                               "coach_dialogue_prediction_basic_v3":  "{Champion} probabilmente andrà in {Position}, al {Chance}%.",
                               "coach_dialogue_prediction_detail":  "I expect {Champion} in {Position}. Based on {Evidence}, the chance is {Chance}%, position win rate is {WinRate}%, average lane gold is {EnemyGold}, and average kills are {EnemyKills}.",
                               "coach_dialogue_prediction_detail_v2":  "The expected position for {Champion} is {Position}. Based on {Evidence}, chance is {Chance}%, win rate is {WinRate}%, and average lane gold is around {EnemyGold}.",
                               "coach_dialogue_prediction_correction_basic":  "I am adjusting the read. {Champion} is now more likely to go {Position} than {PreviousPosition}. Current chance is {Chance}%.",
                               "coach_dialogue_prediction_correction_basic_v2":  "The read on {Champion} has changed. The weight is now on {Position}. Current chance is {Chance}%.",
                               "coach_dialogue_prediction_correction_detail":  "The draft shape changed, so I am adjusting the read. {Champion} now leans {Position}. Based on {Evidence}, chance is {Chance}%, win rate is {WinRate}%, and average lane gold is {EnemyGold}.",
                               "coach_dialogue_recommendation_basic":  "{Position} può essere contrastato con {OurChampion}. Sarebbe bene tenerlo come {CandidateType}.",
                               "coach_dialogue_recommendation_basic_v2":  "For the {Position} response, I recommend {OurChampion}. It would be good to narrow it down as {CandidateType}.",
                               "coach_dialogue_recommendation_basic_v3":  "{OurChampion} is good for {Position}. You can keep it as {CandidateType}.",
                               "coach_dialogue_recommendation_detail":  "Given the flow, it is better to prepare the {Position} response first. Keep {OurChampion} as {CandidateType} and confirm it on the next turn.",
                               "coach_dialogue_recommendation_detail_v2":  "It is better to settle {Position} first. Keeping {OurChampion} as {CandidateType} should make the next pick easier.",
                               "coach_dialogue_general_recommendation_basic":  "For {Position}, it is better to secure {OurChampion} early. It is worth treating as {CandidateType}.",
                               "coach_dialogue_general_recommendation_detail":  "Since {Position} is still open, it is better to secure {OurChampion} early. Raising it in priority as {CandidateType} looks good.",
                               "coach_dialogue_recommendation_support_basic":  "For {Player}, {OurChampion} into {EnemyChampion} shows {SoloKillRate}% solo-kill pressure and a {GoldDiff} lane-gold gap.",
                               "coach_dialogue_recommendation_support_basic_v2":  "By the data, {OurChampion} into {EnemyChampion} shows {SoloKillRate}% solo-kill pressure and a {GoldDiff} lane-gold gap.",
                               "coach_dialogue_recommendation_support_detail":  "For {Player}, {OurChampion} into {EnemyChampion} shows {SoloKillRate}% solo-kill pressure, a {GoldDiff} lane-gold gap, and a {WinRate}% expected edge. {Sample}.",
                               "coach_dialogue_ban_recommendation_basic":  "{OurChampion} is worth moving up as a ban candidate for now.",
                               "coach_dialogue_ban_recommendation_detail":  "At this stage, {OurChampion} should be treated as a higher-priority ban candidate.",
                               "coach_dialogue_ban_warning":  "{Player} ha una proficiency molto alta su {Champion}. Lo raccomando come priorità di ban massima.",
                               "coach_dialogue_ban_warning_v2":  "{Player} su {Champion} è pericoloso. Raccomando di rimuoverlo con un ban.",
                               "coach_dialogue_enemy_tendency":  "L'avversario ha usato recentemente pick come {OurChampion} spesso. Vale la pena prepararsi in anticipo.",
                               "coach_dialogue_enemy_tendency_v2":  "{OurChampion} is a card the opponent often brings out. Since it is likely to appear, it would be better to prepare for it.",
                               "coach_dialogue_weak_lane":  "In the opponent lineup, {Position} is the weakest position. It is worth attacking that point.",
                               "coach_dialogue_weak_lane_v2":  "The attack point is {Position}. The opponent is thinnest at that position.",
                               "coach_dialogue_history_tooltip":  "Staff dialogue history",
                               "coach_dialogue_toast_show_tooltip":  "Show staff dialogue",
                               "coach_dialogue_toast_hide_tooltip":  "Hide staff dialogue",
                               "coach_dialogue_stats_source_team":  "opponent recent record",
                               "coach_dialogue_stats_source_patch":  "patch statistics",
                               "coach_dialogue_stats_source_position_model":  "public pick and position stats",
                               "coach_dialogue_stats_sample_none":  "This estimate is adjusted from patch stats and player records because direct matchup data is limited",
                               "coach_dialogue_evidence_games":  "{Source}, {Sample} games",
                               "coach_dialogue_sample_games":  "This estimate uses {Sample} direct comparison games",
                               "coach_dialogue_unknown_player":  "Opponent player",
                               "coach_dialogue_unknown_position":  "key lane",
                               "coach_dialogue_swap_enemy_prediction":  "At the swap stage, the most likely opponent lane setup is {EnemyLayout}.",
                               "coach_dialogue_swap_allocation":  "For our lane allocation, {OurLayout} looks best. This recommendation weighs player proficiency and champion main positions.",
