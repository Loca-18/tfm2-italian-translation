                               "coach_dialogue_candidate_type_pick":  "pick candidates",
                               "coach_dialogue_opening_analyst":  "Rywal nie ujawnił jeszcze żadnego wyboru. Gdy pojawi się pierwszy pick, najpierw wskażę prawdopodobną pozycję.",
                               "coach_dialogue_opening_analyst_v2":  "Rywal jeszcze nie wybrał. Gdy tylko wybór zostanie ujawniony, podsumuję odczyt pozycji i ostatnie tendencje wyborów.",
                               "coach_dialogue_opening_head":  "Nie trzeba się spieszyć. Najpierw sprawdź pierwszy pick rywala, potem zacznij od jednej z naszych mocnych pozycji.",
                               "coach_dialogue_opening_head_v2":  "Nie ma potrzeby się spieszyć. Po zobaczeniu reakcji rywala dobry będzie pick wykorzystujący nasze mocne strony.",
                               "coach_dialogue_prediction_basic":  "Przewiduję {Champion} na {Position} z prawdopodobieństwem {Chance}%.",
                               "coach_dialogue_prediction_basic_v2":  "Przewidywana pozycja dla {Champion} to {Position}. Prawdopodobieństwo wynosi {Chance}%.",
                               "coach_dialogue_prediction_basic_v3":  "{Champion} najpewniej trafi na {Position}; prawdopodobieństwo {Chance}%.",
                               "coach_dialogue_prediction_detail":  "Spodziewam się {Champion} na {Position}. Według {Evidence}: prawdopodobieństwo {Chance}%, wygrane na tej pozycji {WinRate}%, średnie złoto w linii {EnemyGold}, średnie zabójstwa {EnemyKills}.",
                               "coach_dialogue_prediction_detail_v2":  "Przewidywana pozycja dla {Champion} to {Position}. Według {Evidence}: prawdopodobieństwo {Chance}%, wygrane {WinRate}%, średnie złoto w linii około {EnemyGold}.",
                               "coach_dialogue_prediction_correction_basic":  "Koryguję odczyt. {Champion} ma teraz większą szansę iść na {Position} niż na {PreviousPosition}. Aktualne prawdopodobieństwo: {Chance}%.",
                               "coach_dialogue_prediction_correction_basic_v2":  "Odczyt dla {Champion} się zmienił. Ciężar przechodzi na {Position}. Aktualne prawdopodobieństwo: {Chance}%.",
                               "coach_dialogue_prediction_correction_detail":  "Kształt draftu się zmienił, więc koryguję odczyt. {Champion} skłania się teraz ku {Position}. Według {Evidence}: prawdopodobieństwo {Chance}%, wygrane {WinRate}%, średnie złoto w linii {EnemyGold}.",
                               "coach_dialogue_recommendation_basic":  "Na {Position} można odpowiedzieć przez {OurChampion}. Warto zachować to jako {CandidateType}.",
                               "coach_dialogue_recommendation_basic_v2":  "Jako odpowiedź na {Position} polecam {OurChampion}. Warto zawęzić to jako {CandidateType}.",
                               "coach_dialogue_recommendation_basic_v3":  "Dla {Position} dobrze pasuje {OurChampion}. Można zachować to jako {CandidateType}.",
                               "coach_dialogue_recommendation_detail":  "Patrząc na przebieg draftu, lepiej najpierw przygotować odpowiedź na {Position}. Zachowaj {OurChampion} jako {CandidateType} i potwierdź przy następnym ruchu.",
                               "coach_dialogue_recommendation_detail_v2":  "Lepiej najpierw uporządkować {Position}. Trzymanie {OurChampion} jako {CandidateType} powinno ułatwić następny pick.",
                               "coach_dialogue_general_recommendation_basic":  "Na pozycji {Position} lepiej wcześniej zabezpieczyć {OurChampion}. Warto traktować to jako {CandidateType}.",
                               "coach_dialogue_general_recommendation_detail":  "Ponieważ {Position} wciąż jest otwarte, lepiej wcześniej zabezpieczyć {OurChampion}. Podniesienie priorytetu jako {CandidateType} wygląda dobrze.",
                               "coach_dialogue_recommendation_support_basic":  "Dla {Player}, {OurChampion} przeciwko {EnemyChampion} daje {SoloKillRate}% presji na solo kill i {GoldDiff} różnicy złota w linii.",
                               "coach_dialogue_recommendation_support_basic_v2":  "Według danych, {OurChampion} przeciwko {EnemyChampion} daje {SoloKillRate}% presji na solo kill i {GoldDiff} różnicy złota w linii.",
                               "coach_dialogue_recommendation_support_detail":  "Dla {Player}, {OurChampion} przeciwko {EnemyChampion} pokazuje {SoloKillRate}% presji na solo kill, {GoldDiff} różnicy złota w linii i {WinRate}% oczekiwanej przewagi. {Sample}.",
                               "coach_dialogue_ban_recommendation_basic":  "Na razie warto podnieść {OurChampion} jako kandydata do bana.",
                               "coach_dialogue_ban_recommendation_detail":  "Na tym etapie {OurChampion} powinno być traktowane jako kandydat do bana o wyższym priorytecie.",
                               "coach_dialogue_ban_warning":  "{Player} ma bardzo wysoką biegłość na {Champion}. Polecam jako najwyższy priorytet bana.",
                               "coach_dialogue_ban_warning_v2":  "{Champion} w rękach {Player} jest groźny. Polecam zdjąć go banem.",
                               "coach_dialogue_enemy_tendency":  "Rywal ostatnio często używa wyborów takich jak {OurChampion}. Warto przygotować odpowiedź wcześniej.",
