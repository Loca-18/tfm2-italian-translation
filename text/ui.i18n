                               "coach_dialogue_stats_source_patch":  "patch statistics",
                               "coach_dialogue_stats_source_position_model":  "openbare picks en positiestatistieken",
                               "coach_dialogue_stats_sample_none":  "Omdat directe matchupdata beperkt is, is deze waarde bijgesteld met patchstatistieken en spelersrecords",
                               "coach_dialogue_evidence_games":  "{Source}, {Sample} games",
                               "coach_dialogue_sample_games":  "Deze waarde gebruikt {Sample} directe vergelijkingswedstrijden",
                               "coach_dialogue_unknown_player":  "Opponent player",
                               "coach_dialogue_unknown_position":  "key lane",
                               "coach_dialogue_swap_enemy_prediction":  "In de swapfase lijkt de meest waarschijnlijke lane-indeling van de tegenstander {EnemyLayout}.",
                               "coach_dialogue_swap_allocation":  "Voor onze lane-indeling ziet {OurLayout} er het beste uit. Dit advies weegt spelersvaardigheid en de hoofdposities van champions mee.",
