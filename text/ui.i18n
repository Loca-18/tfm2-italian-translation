                               "coach_dialogue_opening_head":  "Haasten is niet nodig. Controleer eerst hun eerste pick en begin daarna bij een van onze sterke posities.",
                               "coach_dialogue_opening_head_v2":  "Er hoeft geen haast bij. Na hun reactie is een pick die onze sterktes benut een goede richting.",
                               "coach_dialogue_prediction_basic":  "Ik schat {Champion} op {Position} met {Chance}% kans.",
                               "coach_dialogue_prediction_basic_v2":  "De verwachte positie voor {Champion} is {Position}. De kans is {Chance}%.",
                               "coach_dialogue_prediction_basic_v3":  "{Champion} gaat waarschijnlijk naar {Position}, met {Chance}% kans.",
                               "coach_dialogue_prediction_detail":  "Ik verwacht {Champion} op {Position}. Op basis van {Evidence}: kans {Chance}%, winstpercentage op die positie {WinRate}%, gemiddelde lane-gold {EnemyGold}, gemiddeld {EnemyKills} kills.",
                               "coach_dialogue_prediction_detail_v2":  "De verwachte positie voor {Champion} is {Position}. Op basis van {Evidence}: kans {Chance}%, winstpercentage {WinRate}%, gemiddelde lane-gold rond {EnemyGold}.",
                               "coach_dialogue_prediction_correction_basic":  "Ik stel de verwachting bij. {Champion} lijkt nu eerder naar {Position} te gaan dan naar {PreviousPosition}. Huidige kans: {Chance}%.",
                               "coach_dialogue_prediction_correction_basic_v2":  "De verwachting rond {Champion} is veranderd. Het gewicht ligt nu bij {Position}. Huidige kans: {Chance}%.",
                               "coach_dialogue_prediction_correction_detail":  "De draft is veranderd, dus ik stel de verwachting bij. {Champion} neigt nu naar {Position}. Op basis van {Evidence}: kans {Chance}%, winstpercentage {WinRate}%, gemiddelde lane-gold {EnemyGold}.",
                               "coach_dialogue_recommendation_basic":  "{Position} kan worden beantwoord met {OurChampion}. Het is goed om die als {CandidateType} klaar te zetten.",
                               "coach_dialogue_recommendation_basic_v2":  "Als antwoord op {Position} raad ik {OurChampion} aan. Het is goed om die als {CandidateType} te selecteren.",
                               "coach_dialogue_recommendation_basic_v3":  "{OurChampion} is goed voor {Position}. Die kan als {CandidateType} worden vastgehouden.",
                               "coach_dialogue_recommendation_detail":  "Gezien het verloop is het beter om eerst het antwoord op {Position} voor te bereiden. Houd {OurChampion} als {CandidateType} en bevestig in de volgende beurt.",
                               "coach_dialogue_recommendation_detail_v2":  "Het is beter om {Position} eerst af te handelen. Met {OurChampion} als {CandidateType} wordt de volgende pick makkelijker.",
                               "coach_dialogue_general_recommendation_basic":  "Voor {Position} is het beter om {OurChampion} vroeg vast te leggen. Die is het waard als {CandidateType}.",
                               "coach_dialogue_general_recommendation_detail":  "Omdat {Position} nog open is, is het beter om {OurChampion} vroeg vast te leggen. Een hogere prioriteit als {CandidateType} ziet er goed uit.",
                               "coach_dialogue_recommendation_support_basic":  "Voor {Player} laat {OurChampion} tegen {EnemyChampion} {SoloKillRate}% solo-killdruk en {GoldDiff} verschil in lane-gold zien.",
                               "coach_dialogue_recommendation_support_basic_v2":  "Volgens de data laat {OurChampion} tegen {EnemyChampion} {SoloKillRate}% solo-killdruk en {GoldDiff} verschil in lane-gold zien.",
                               "coach_dialogue_recommendation_support_detail":  "Voor {Player} laat {OurChampion} tegen {EnemyChampion} {SoloKillRate}% solo-killdruk, {GoldDiff} verschil in lane-gold en {WinRate}% verwacht voordeel zien. {Sample}.",
                               "coach_dialogue_ban_recommendation_basic":  "{OurChampion} is het waard om nu hoger te zetten als bankandidaat.",
                               "coach_dialogue_ban_recommendation_detail":  "In deze fase moet {OurChampion} als bankandidaat met hogere prioriteit worden behandeld.",
                               "coach_dialogue_ban_warning":  "{Player} heeft zeer hoge vaardigheid met {Champion}. Ik raad dit aan als hoogste banprioriteit.",
                               "coach_dialogue_ban_warning_v2":  "{Champion} bij {Player} is gevaarlijk. Ik raad aan om die met een ban weg te halen.",
                               "coach_dialogue_enemy_tendency":  "De tegenstander gebruikte recent vaak picks zoals {OurChampion}. Voorbereiden is verstandig.",
                               "coach_dialogue_enemy_tendency_v2":  "{OurChampion} is een kaart die de tegenstander vaak speelt. Omdat de kans groot is dat die verschijnt, is voorbereiden beter.",
                               "coach_dialogue_weak_lane":  "In de opstelling van de tegenstander is {Position} de zwakste positie. Dat punt is het aanvallen waard.",
                               "coach_dialogue_weak_lane_v2":  "Het aanvalspunt is {Position}. De tegenstander is daar het dunst bezet.",
                               "coach_dialogue_history_tooltip":  "Staff dialogue history",
                               "coach_dialogue_toast_show_tooltip":  "Show staff dialogue",
                               "coach_dialogue_toast_hide_tooltip":  "Hide staff dialogue",
