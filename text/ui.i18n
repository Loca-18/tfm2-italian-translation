                               "enemy_most_tooltip":  "Most-Played Champion: <#eb3d4dff>{Name}<>.",
                               "position_buff_tooltip":  "{PositionName}: {BuffDesc}",
                               "most_champion_bonus_tooltip":  "{ChampionName}: Most-Played Champion dieses Spielers. Wird er gespielt, gibt es +{Value}% Werte-Bonus.",
                               "coach_dialogue_title":  "Staff Dialogue",
                               "coach_dialogue_role_head":  "Head Coach",
                               "coach_dialogue_role_analyst":  "Analyst",
                               "coach_dialogue_role_staff":  "Coach",
                               "coach_dialogue_candidate_type_ban":  "ban candidates",
                               "coach_dialogue_candidate_type_pick":  "pick candidates",
                               "coach_dialogue_opening_analyst":  "Der Gegner hat noch keinen Pick offengelegt. Sobald der erste Pick erscheint, nenne ich zuerst die wahrscheinliche Position.",
                               "coach_dialogue_opening_analyst_v2":  "Der Gegner hat noch nicht gepickt. Sobald der Pick offen ist, fasse ich die Positionslese und die jüngsten Pick-Tendenzen zusammen.",
                               "coach_dialogue_opening_head":  "Kein Grund zur Eile. Erst den ersten gegnerischen Pick prüfen, dann von einer unserer starken Positionen aus starten.",
                               "coach_dialogue_opening_head_v2":  "Es muss nicht überstürzt werden. Nach der gegnerischen Reaktion ist ein Pick gut, der unsere Stärken nutzt.",
                               "coach_dialogue_prediction_basic":  "Ich erwarte {Champion} mit {Chance}% Wahrscheinlichkeit auf {Position}.",
                               "coach_dialogue_prediction_basic_v2":  "Die erwartete Position für {Champion} ist {Position}. Die Wahrscheinlichkeit liegt bei {Chance}%.",
                               "coach_dialogue_prediction_basic_v3":  "{Champion} geht mit {Chance}% Wahrscheinlichkeit am ehesten auf {Position}.",
                               "coach_dialogue_prediction_detail":  "Ich erwarte {Champion} auf {Position}. Nach {Evidence} liegt die Wahrscheinlichkeit bei {Chance}%, die Positions-Siegrate bei {WinRate}%, durchschnittliches Lane-Gold bei {EnemyGold} und durchschnittliche Kills bei {EnemyKills}.",
                               "coach_dialogue_prediction_detail_v2":  "Die erwartete Position für {Champion} ist {Position}. Nach {Evidence}: Wahrscheinlichkeit {Chance}%, Siegrate {WinRate}%, durchschnittliches Lane-Gold etwa {EnemyGold}.",
                               "coach_dialogue_prediction_correction_basic":  "Ich korrigiere die Einschätzung. {Champion} ist jetzt eher {Position} als {PreviousPosition}. Aktuelle Wahrscheinlichkeit: {Chance}%.",
                               "coach_dialogue_prediction_correction_basic_v2":  "Die Einschätzung zu {Champion} hat sich geändert. Das Gewicht liegt jetzt auf {Position}. Aktuelle Wahrscheinlichkeit: {Chance}%.",
                               "coach_dialogue_prediction_correction_detail":  "Durch die neue Draft-Lage korrigiere ich die Einschätzung. {Champion} tendiert zu {Position}. Nach {Evidence}: Wahrscheinlichkeit {Chance}%, Siegrate {WinRate}%, durchschnittliches Lane-Gold {EnemyGold}.",
                               "coach_dialogue_recommendation_basic":  "{Position} lässt sich mit {OurChampion} beantworten. Es wäre gut, es als {CandidateType} bereitzuhalten.",
                               "coach_dialogue_recommendation_basic_v2":  "Als Antwort auf {Position} empfehle ich {OurChampion}. Es wäre gut, es als {CandidateType} einzugrenzen.",
                               "coach_dialogue_recommendation_basic_v3":  "Für {Position} passt {OurChampion} gut. Es kann als {CandidateType} festgehalten werden.",
                               "coach_dialogue_recommendation_detail":  "Vom Verlauf her ist es besser, zuerst die Antwort auf {Position} vorzubereiten. {OurChampion} als {CandidateType} halten und im nächsten Zug bestätigen.",
                               "coach_dialogue_recommendation_detail_v2":  "Es ist besser, zuerst {Position} zu klären. Wenn {OurChampion} als {CandidateType} bereitsteht, wird der nächste Pick leichter.",
                               "coach_dialogue_general_recommendation_basic":  "Für {Position} ist es besser, {OurChampion} früh zu sichern. Es passt als {CandidateType}.",
                               "coach_dialogue_general_recommendation_detail":  "Da {Position} noch offen ist, ist es besser, {OurChampion} früh zu sichern. Es sieht gut aus, es als {CandidateType} höher zu priorisieren.",
                               "coach_dialogue_recommendation_support_basic":  "Für {Player} zeigt {OurChampion} gegen {EnemyChampion} {SoloKillRate}% Solo-Kill-Druck und {GoldDiff} Lane-Gold-Differenz.",
                               "coach_dialogue_recommendation_support_basic_v2":  "Nach den Daten zeigt {OurChampion} gegen {EnemyChampion} {SoloKillRate}% Solo-Kill-Druck und {GoldDiff} Lane-Gold-Differenz.",
                               "coach_dialogue_recommendation_support_detail":  "Für {Player} zeigt {OurChampion} gegen {EnemyChampion} {SoloKillRate}% Solo-Kill-Druck, {GoldDiff} Lane-Gold-Differenz und {WinRate}% erwarteten Vorteil. {Sample}.",
                               "coach_dialogue_ban_recommendation_basic":  "{OurChampion} sollte jetzt als Bannkandidat nach oben geschoben werden.",
                               "coach_dialogue_ban_recommendation_detail":  "In dieser Phase sollte {OurChampion} als Bannkandidat höhere Priorität bekommen.",
                               "coach_dialogue_ban_warning":  "{Player} hat sehr hohe Meisterschaft auf {Champion}. Ich empfehle es als Ban-Priorität Nummer eins.",
                               "coach_dialogue_ban_warning_v2":  "{Player} auf {Champion} ist gefährlich. Ich empfehle, es per Ban zu entfernen.",
                               "coach_dialogue_enemy_tendency":  "Der Gegner hat zuletzt Picks wie {OurChampion} häufig genutzt. Darauf sollten wir uns vorbereiten.",
                               "coach_dialogue_enemy_tendency_v2":  "{OurChampion} ist eine Karte, die der Gegner oft zieht. Da sie wahrscheinlich erscheint, wäre Vorbereitung darauf sinnvoll.",
                               "coach_dialogue_weak_lane":  "In der gegnerischen Aufstellung ist {Position} die schwächste Position. Diesen Punkt kann man angreifen.",
                               "coach_dialogue_weak_lane_v2":  "Der Angriffspunkt ist {Position}. Dort ist die gegnerische Stärke am dünnsten.",
                               "coach_dialogue_history_tooltip":  "Staff dialogue history",
                               "coach_dialogue_toast_show_tooltip":  "Show staff dialogue",
                               "coach_dialogue_toast_hide_tooltip":  "Hide staff dialogue",
