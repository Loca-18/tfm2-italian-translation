                                          "tab_stat":  "能力值",
                                          "tab_aptitude":  "適性",
                                          "tab_potential":  "潛力",
                                          "position_header":  "位置",
                                          "add_position":  "添加位置",
                                          "communication_header":  "溝通水平",
                                          "add_language":  "添加賽區",
                                          "growth_header":  "成長",
                                          "potential":  "潛力",
                                          "stamina_recovery_min":  "體力恢復最小值",
                                          "stamina_recovery_max":  "體力恢復最大值",
                                          "stamina_cost_per_set_min":  "體力消耗最小值",
                                          "stamina_cost_per_set_max":  "體力消耗最大值",
                                          "stress_sensitivity":  "壓力敏感度",
                                          "condition_baseline":  "狀態基準值",
                                          "condition_amplitude":  "狀態起伏程度",
                                          "condition_period":  "狀態起伏週期",
                                          "condition_phase":  "狀態起伏相位",
                                          "match_impact_sensitivity":  "比賽結果重視度",
                                          "fan_count":  "粉絲數",
                                          "description":  {
                                                              "potential":  "該能力值越高，就越容易通過訓練獲得成長，同時成長潛力等級也會更高。",
                                                              "stamina_recovery_min":  "每日恢復體力隨機幅度的最小值。",
                                                              "stamina_recovery_max":  "每日恢復體力隨機幅度的最大值。",
                                                              "stamina_cost_per_set_min":  "參加一局比賽時所消耗體力隨機幅度的最小值。實際消耗量將根據比賽時間進行校正。",
                                                              "stamina_cost_per_set_max":  "參加一局比賽時所消耗體力隨機幅度的最大值。實際消耗量將根據比賽時間進行校正。",
                                                              "stress_sensitivity":  "該能力值越高，在休息不足時壓力就越容易累積，並且通過休息所減少的壓力幅度也越小。",
                                                              "condition_baseline":  "狀態圍繞基準值進行波動，基準值越高，總體狀態越好。",
                                                              "condition_amplitude":  "該能力值越高，選手狀態圍繞基準值的變化幅度就越大，即狀態波動上下限範圍越大。",
                                                              "condition_period":  "完成一個狀態變化週期所需的天數。該數值越低，狀態波動的情況就越頻繁，越容易在狀態最佳與狀態最差間不斷轉換。",
                                                              "condition_phase":  "該值用於前後推移狀態變化的具體日期。當相位不同時，即使兩名選手狀態週期相同，他們各自狀態好與狀態差的日子到來的時間點也不同。",
                                                              "match_impact_sensitivity":  "比賽後勝負及是否獲得mvp對狀態造成影響的強弱程度。50爲標準值，0表示完全沒有影響，100表示影響加倍。",
                                                              "fan_count":  "選手的粉絲數量。用於計算直播觀衆數、商品銷量以及比賽後選手粉絲數量的變化。"
                                                          },
