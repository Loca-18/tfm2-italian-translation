                               "most_champion_bonus_tooltip":  "{ChampionName}: Tướng tủ của Tuyển thủ này. Khi sử dụng, Chỉ số của Tuyển thủ sẽ tăng {Value}%.",
                               "coach_dialogue_title":  "Staff Dialogue",
                               "coach_dialogue_role_head":  "Head Coach",
                               "coach_dialogue_role_analyst":  "Analyst",
                               "coach_dialogue_role_staff":  "Coach",
                               "coach_dialogue_candidate_type_ban":  "ban candidates",
                               "coach_dialogue_candidate_type_pick":  "pick candidates",
                               "coach_dialogue_opening_analyst":  "Đối thủ chưa công khai lượt chọn nào. Khi lượt chọn đầu tiên xuất hiện, tôi sẽ chỉ ra vị trí dự kiến trước.",
                               "coach_dialogue_opening_analyst_v2":  "Đối thủ vẫn chưa chọn. Khi lựa chọn được công khai, tôi sẽ tóm tắt vị trí dự đoán và xu hướng chọn gần đây.",
                               "coach_dialogue_opening_head":  "Không cần vội. Hãy xem lượt chọn đầu của đối thủ trước, rồi bắt đầu từ vị trí mạnh của ta.",
                               "coach_dialogue_opening_head_v2":  "Không cần hấp tấp. Sau khi thấy phản ứng của đối thủ, chọn theo điểm mạnh của ta sẽ tốt hơn.",
                               "coach_dialogue_prediction_basic":  "Tôi dự đoán {Champion} có {Chance}% khả năng được dùng ở {Position}.",
                               "coach_dialogue_prediction_basic_v2":  "Vị trí dự kiến của {Champion} là {Position}. Xác suất là {Chance}%.",
                               "coach_dialogue_prediction_basic_v3":  "{Champion} nhiều khả năng đi {Position}, với xác suất {Chance}%.",
                               "coach_dialogue_prediction_detail":  "Tôi dự đoán {Champion} ở {Position}. Theo {Evidence}, xác suất là {Chance}%, tỉ lệ thắng vị trí {WinRate}%, vàng trung bình khi đi đường {EnemyGold}, trung bình {EnemyKills} mạng.",
                               "coach_dialogue_prediction_detail_v2":  "Vị trí dự kiến của {Champion} là {Position}. Theo {Evidence}, xác suất {Chance}%, tỉ lệ thắng {WinRate}%, vàng trung bình khi đi đường khoảng {EnemyGold}.",
                               "coach_dialogue_prediction_correction_basic":  "Tôi điều chỉnh dự đoán. {Champion} hiện có khả năng đi {Position} cao hơn {PreviousPosition}. Xác suất hiện tại là {Chance}%.",
                               "coach_dialogue_prediction_correction_basic_v2":  "Dự đoán về {Champion} đã thay đổi. Trọng tâm đang nghiêng về {Position}. Xác suất hiện tại là {Chance}%.",
                               "coach_dialogue_prediction_correction_detail":  "Cục diện draft đã đổi nên tôi điều chỉnh dự đoán. {Champion} đang nghiêng về {Position}. Theo {Evidence}, xác suất {Chance}%, tỉ lệ thắng {WinRate}%, vàng trung bình khi đi đường {EnemyGold}.",
                               "coach_dialogue_recommendation_basic":  "{Position} có thể đáp trả bằng {OurChampion}. Nên giữ trong nhóm {CandidateType}.",
                               "coach_dialogue_recommendation_basic_v2":  "Để đáp trả {Position}, tôi đề xuất {OurChampion}. Nên thu hẹp vào nhóm {CandidateType}.",
                               "coach_dialogue_recommendation_basic_v3":  "{OurChampion} phù hợp cho {Position}. Có thể giữ làm {CandidateType}.",
                               "coach_dialogue_recommendation_detail":  "Theo nhịp draft, nên chuẩn bị phương án cho {Position} trước. Giữ {OurChampion} trong nhóm {CandidateType} rồi chốt ở lượt sau sẽ hợp lý.",
                               "coach_dialogue_recommendation_detail_v2":  "Nên xử lý {Position} trước. Giữ {OurChampion} trong nhóm {CandidateType} sẽ giúp lượt chọn tiếp theo dễ hơn.",
                               "coach_dialogue_general_recommendation_basic":  "Ở vị trí {Position}, nên lấy sớm {OurChampion}. Có thể xem đó là {CandidateType}.",
                               "coach_dialogue_general_recommendation_detail":  "Vì {Position} vẫn còn trống, nên lấy sớm {OurChampion}. Nâng ưu tiên trong nhóm {CandidateType} là hướng tốt.",
                               "coach_dialogue_recommendation_support_basic":  "Với {Player}, {OurChampion} đấu {EnemyChampion} cho thấy áp lực solo kill {SoloKillRate}% và chênh lệch vàng đi đường {GoldDiff}.",
                               "coach_dialogue_recommendation_support_basic_v2":  "Theo dữ liệu, {OurChampion} đấu {EnemyChampion} có áp lực solo kill {SoloKillRate}% và chênh lệch vàng đi đường {GoldDiff}.",
                               "coach_dialogue_recommendation_support_detail":  "Với {Player}, {OurChampion} đấu {EnemyChampion} cho thấy áp lực solo kill {SoloKillRate}%, chênh lệch vàng đi đường {GoldDiff}, và lợi thế kỳ vọng {WinRate}%. {Sample}.",
                               "coach_dialogue_ban_recommendation_basic":  "Lúc này nên đưa {OurChampion} lên trước trong nhóm mục tiêu cấm.",
                               "coach_dialogue_ban_recommendation_detail":  "Ở giai đoạn này, {OurChampion} nên được ưu tiên cao hơn trong nhóm mục tiêu cấm.",
                               "coach_dialogue_ban_warning":  "{Player} có độ thuần thục rất cao với {Champion}. Tôi khuyến nghị ưu tiên ban số một.",
                               "coach_dialogue_ban_warning_v2":  "{Champion} trong tay {Player} rất nguy hiểm. Tôi khuyến nghị loại bỏ bằng ban.",
                               "coach_dialogue_enemy_tendency":  "Gần đây đối thủ thường dùng các lựa chọn như {OurChampion}. Nên chuẩn bị trước.",
                               "coach_dialogue_enemy_tendency_v2":  "{OurChampion} là quân bài đối thủ thường dùng. Khả năng xuất hiện cao, nên chuẩn bị trước sẽ tốt hơn.",
                               "coach_dialogue_weak_lane":  "Trong đội hình đối thủ, {Position} là vị trí yếu nhất. Có thể nhắm vào điểm này.",
                               "coach_dialogue_weak_lane_v2":  "Điểm tấn công là {Position}. Sức mạnh của đối thủ mỏng nhất ở vị trí này.",
                               "coach_dialogue_history_tooltip":  "Staff dialogue history",
                               "coach_dialogue_toast_show_tooltip":  "Show staff dialogue",
